*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/
**/[Pp]ackages/
nuget.config

# ---------------------------
# MSBuild
# ---------------------------
*.log
*.binlog

# ---------------------------
